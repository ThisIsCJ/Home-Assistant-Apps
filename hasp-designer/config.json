{
  "name": "openHASP Designer",
  "version": "1.0.0",
  "slug": "hasp-designer",
  "description": "Visual screen designer for openHASP panels. Design pages with drag-and-drop, then export to JSONL.",
  "url": "https://github.com/ThisIsCJ/Home-Assistant-Apps",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:monitor-edit",
  "panel_title": "HASP Designer",
  "options": {
    "panel_width": 480,
    "panel_height": 480
  },
  "schema": {
    "panel_width": "int",
    "panel_height": "int"
  }
}
