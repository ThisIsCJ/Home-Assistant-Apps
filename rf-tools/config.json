{
  "name": "RF Tools",
  "version": "1.0.0",
  "slug": "rf-tools",
  "description": "A modern add-on for learning and replaying ESPHome RF remotes inside a clean Home Assistant UI.",
  "url": "https://github.com/ThisIsCJ/Home-Assistant-Apps",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:remote",
  "panel_title": "RF Tools",
  "options": {
    "devices": []
  },
  "schema": {
    "devices": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "learn_entity": { "type": "string" },
          "sensor_entity": { "type": "string" },
          "transmit_service": { "type": "string", "default": "esphome.transmit_rf" }
        },
        "required": ["name", "learn_entity", "sensor_entity"]
      }
    }
  }
}
