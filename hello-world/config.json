{
  "name": "Hello World",
  "version": "1.0.0",
  "slug": "hello-world",
  "description": "A minimal example add-on that displays a greeting in the sidebar.",
  "url": "https://github.com/ThisIsCJ/Home-Assistant-Apps",
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:hand-wave",
  "panel_title": "Hello World",
  "options": {
    "greeting": "Hello, Home Assistant!"
  },
  "schema": {
    "greeting": "str"
  }
}
