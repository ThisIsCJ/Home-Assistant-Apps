# URL the bridge uses internally to reach the Health Tracker API container
HT_SERVER_URL=http://api:4000

# An ht_ API token from the HT web app: Settings → API Tokens → Create
HT_API_TOKEN=ht_your_token_here

# Credentials to use if you configure Sparky in session-login mode
# (not needed in API-key mode — just paste HT_API_TOKEN directly into Sparky)
BRIDGE_EMAIL=you@example.com
BRIDGE_PASSWORD=changeme

# Daily goals returned to the Sparky app
GOAL_CALORIES=2000
GOAL_PROTEIN_G=150
GOAL_CARBS_G=225
GOAL_FAT_G=65
GOAL_WATER_ML=2500
GOAL_STEPS=10000

# Sub-path the bridge is served under (must match your NPM custom location)
# Leave blank if nginx strips the prefix before forwarding
SPARKY_ROOT_PATH=/sparky
